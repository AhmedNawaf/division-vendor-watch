{
  "name": "division-vendor-watch-worker",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Worker: Discord HTTP interactions endpoint for the vendor-watch bot.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "register": "node --env-file-if-exists=.dev.vars --import tsx scripts/register-commands.ts",
    "local": "node --env-file-if-exists=.dev.vars --import tsx scripts/local-sign.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260714.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "wrangler": "^4.0.0"
  }
}
