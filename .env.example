# Copy to .env and fill in. Never commit the real .env.

# Required to actually deliver alerts (omit for DRY_RUN).
DISCORD_WEBHOOK_URL=

# Optional overrides (defaults shown).
VENDOR_URL=https://rubenalamina.mx/the-division-weekly-vendor-reset/
WATCHLIST_PATH=config/watchlist.json
ALERT_HISTORY_PATH=data/alert-history.json
REQUEST_TIMEOUT_MS=15000

# When true, parse and print alerts without sending to Discord or writing history.
DRY_RUN=false


# IANA time zone used to display the weekly reset stamp. Defaults to Asia/Riyadh (KSA, UTC+3).
RESET_TIMEZONE=Asia/Riyadh
