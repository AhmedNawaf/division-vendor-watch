{
  "name": "division-vendor-watch",
  "version": "0.1.0",
  "private": true,
  "description": "Watch The Division 2 weekly vendor reset and alert on watchlisted items via Discord.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "division-vendor-watch": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "dev": "node --env-file-if-exists=.env --import tsx src/index.ts",
    "inspect": "tsx scripts/inspect-source.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/node": "^20.14.0",
    "eslint": "^9.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.10"
  }
}
